{
  "name": "scrapeman",
  "version": "0.0.0",
  "private": true,
  "description": "Postman-grade API client for scrape-do workflows",
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --filter=./packages/* build && pnpm --filter=@scrapeman/desktop build",
    "dev": "pnpm run build:packages && concurrently -n types,core,desktop -c cyan,magenta,green \"pnpm --filter=@scrapeman/shared-types dev\" \"pnpm --filter=@scrapeman/http-core dev\" \"pnpm --filter=@scrapeman/desktop dev\"",
    "build:packages": "pnpm -r --filter=./packages/* build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "verify": "pnpm -r typecheck && pnpm -r test",
    "hooks:install": "ln -sf ../../scripts/pre-push.sh .git/hooks/pre-push && chmod +x scripts/pre-push.sh"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "concurrently": "^9.1.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "@electron/winstaller",
      "core-js",
      "dmg-license"
    ]
  }
}
